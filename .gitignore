# --- Environment & Secrets ---
.env
.env.local
.env.production
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
*.egg

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Flutter/Dart ---
frontend/.dart_tool/
frontend/.packages
frontend/build/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies

# --- Docker ---
docker-compose.override.yml

# --- Database ---
database/data/
*.db
*.sqlite

# --- Logs ---
logs/
*.log

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

